{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git push:*)",
      "Bash(make:*)",
      "Bash(moq:*)",
      "Bash(APP_KEY=dummy go test:*)",
      "Bash(gh pr:*)",
      "Bash(git clone:*)",
      "Bash(git apply)",
      "Bash(claude mcp:*)",
      "Read(//Users/sanyamasahiro/Desktop/**)",
      "Read(//Users/sanyamasahiro/Downloads/**)",
      "Read(//Users/sanyamasahiro/src/palmu/**)",
      "Read(//Users/sanyamasahiro/.claude/**)",
      "Read(//private/tmp/**)",
      "mcp__notion__notion-fetch",
      "mcp__notion__notion-create-pages",
      "mcp__notion__notion-update-page",
      "mcp__drawio__open_drawio_mermaid",
      "mcp__drawio__open_drawio_xml",
      "WebSearch",
      "WebFetch(domain:zenn.dev)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:www.drawio.com)",
      "WebFetch(domain:blog.serverworks.co.jp)",
      "mcp__plugin_slack_slack__slack_search_public",
      "Skill(create-design-doc)",
      "Skill(create-design-doc:*)",
      "mcp__gcloud__run_gcloud_command",
      "Bash(gcloud logging:*)",
      "Bash(git checkout:*)",
      "Bash(git pull:*)",
      "Bash(git branch:*)",
      "mcp__plugin_slack_slack__slack_send_message",
      "mcp__notion__notion-search",
      "mcp__plugin_slack_slack__slack_read_thread"
    ],
    "defaultMode": "auto",
    "additionalDirectories": [
      "/Users/sanyamasahiro/src/palmu/palmu-api-go/.git",
      "/private/tmp",
      "/Users/sanyamasahiro/Desktop",
      "/private/tmp/palmu-conflict-check",
      "/Users/sanyamasahiro/src/palmu/palmu-devops/.claude"
    ]
  },
  "enableAllProjectMcpServers": false,
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Glass.aiff &"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Ping.aiff &"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh",
    "padding": 1
  },
  "enabledPlugins": {
    "light-skills-updater@light-skills": true,

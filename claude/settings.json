{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git push:*)",
      "Bash(make:*)",
      "Bash(moq:*)",
      "Bash(APP_KEY=dummy go test:*)",
      "Bash(gh pr:*)",
      "Bash(git clone:*)",
      "Bash(git apply)",
      "Bash(claude mcp:*)",
      "WebSearch",
      "Bash(gcloud logging:*)",
      "Bash(git checkout:*)",
      "Bash(git pull:*)",
      "Bash(git branch:*)",
      "Bash(rg:*)",
      "Bash(fd:*)",
      "Bash(bat:*)",
      "Bash(jq:*)",
      "Bash(fzf:*)",
      "Bash(tree:*)",
      "mcp__serena__find_symbol",
      "mcp__serena__search_for_pattern",
      "mcp__serena__get_symbols_overview",
      "mcp__serena__find_file",
      "mcp__serena__find_referencing_symbols",
      "mcp__serena__list_dir",
      "mcp__serena__read_memory",
      "mcp__serena__list_memories"
    ],
    "defaultMode": "auto"
  },
  "enableAllProjectMcpServers": false,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/guard-bash-command.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/guard-review-push.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/guard-test-skip.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/wezterm-status.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/wezterm-status.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/wezterm-status.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/claude-stop-notify.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/wezterm-status.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/wezterm-status.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/wezterm-status.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Ping.aiff &",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/wezterm-status.sh",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh",
    "padding": 1
  },
  "enabledPlugins": {
    "slack@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "dev-ticket@light-skills": true,
    "github-analyze-member@light-skills": false,
    "fix-pr-reviews@light-skills": true,
    "light-skills-updater@light-skills": true,
    "member-report-manager@light-skills": false,
    "gcp-monitoring@light-skills": true,
    "claude-session-manager@light-skills": true,
    "stack-pr-merge@light-skills": true,
    "dojo@light-skills": false,
    "slack-tools@light-skills": false,
    "retrospective-tools@light-skills": true,
    "quarterly-evaluation-generator@light-skills": true,
    "gogcli@light-skills": true,
    "offboarding-checker@light-skills": false,
    "gcp-prod-guard@light-skills": true,
    "check-release-pr@light-skills": true,
    "gcp-log-tools@light-skills": true,
    "palmu-api-doc@light-skills": true,
    "run-playwright@light-skills": true,
    "win-session-tools@light-skills": false,
    "post-release-check@light-skills": true,
    "generate-test-spec@light-skills": true,
    "slack-1on1-feedback@light-skills": false,
    "prepare-release-staging@light-skills": true,
    "cmux-handoff@light-skills": true,
    "new-desktop-app@light-skills": false,
    "new-web-app@light-skills": false,
    "lhs@light-skills": false,
    "infra-check@light-skills": true,
    "palmu-ai-dashboard-collector@light-skills": true,
    "konishi@light-skills": false,
    "create-slides@light-skills": true,
    "create-html@light-skills": true,
    "collect-feed@light-skills": true,
    "fukai@light-skills": false,
    "claude-code-toolkit@light-skills": true,
    "ai-slop-review@light-skills": true,
    "app-security-check@light-skills": true,
    "check-release-cross-repo@light-skills": true,
    "superpowers@superpowers-marketplace": true,
    "document-skills@anthropic-agent-skills": true,
    "example-skills@anthropic-agent-skills": false
  },
  "extraKnownMarketplaces": {
    "light-skills": {
      "source": {
        "source": "github",
        "repo": "light-inc/light-skills"
      }
    },
    "superpowers-marketplace": {
      "source": {
        "source": "github",
        "repo": "obra/superpowers-marketplace"
      }
    },
    "anthropic-agent-skills": {
      "source": {
        "source": "github",
        "repo": "anthropics/skills"
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "theme": "dark",
  "skipAutoPermissionPrompt": true
}

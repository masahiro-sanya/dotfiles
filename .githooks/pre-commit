#!/bin/bash
# dotfiles pre-commit: staged ファイルのみを対象にした軽量チェック
# - claude/settings.json: JSON 妥当性 + ランタイムフィールド（コミット禁止）の検出
# - 全 staged ファイル: 高確度の秘密パターン検知（AWSキー・GitHub PAT・秘密鍵 等）
# - *.sh: bash -n（staged 内容で検証）
# - claude/hooks/*.sh が staged のときだけ hooks 回帰テストを実行
# 配線: setup.sh が `git config core.hooksPath .githooks` を設定する
# macOS 標準 bash 3.2 互換で書く

set -u

fail=0

err() {
    printf 'pre-commit: %s\n' "$1" >&2
    fail=1
}

staged="$(git diff --cached --name-only --diff-filter=ACMR)"
if [ -z "${staged}" ]; then
    exit 0
fi

run_hook_tests=0

# 高確度の秘密パターン（形式が確定的なもののみ。誤検知を抑えるため緩いパターンは入れない）
# AWS アクセスキー / GitHub PAT（新旧）/ Slack token / Anthropic API key / Google API key / PEM 秘密鍵
secret_pat='AKIA[0-9A-Z]{16}|ghp_[A-Za-z0-9]{36}|github_pat_[A-Za-z0-9_]{22,}|xox[baprs]-[0-9A-Za-z-]{10,}|sk-ant-[A-Za-z0-9_-]{20,}|AIza[0-9A-Za-z_-]{35}|-----BEGIN( [A-Z]+)? PRIVATE KEY-----'

while IFS= read -r f; do
    case "${f}" in
        claude/settings.json)
            content="$(git show :claude/settings.json)"
            if ! printf '%s\n' "${content}" | jq . >/dev/null 2>&1; then
                err "claude/settings.json が JSON としてパースできません"
            else
                bad="$(printf '%s\n' "${content}" | jq -r 'keys[] | select(. == "model" or . == "effortLevel" or . == "tui" or . == "skipWorkflowUsageWarning" or . == "agentPushNotifEnabled" or . == "skipDangerousModePermissionPrompt")')"
                if [ -n "${bad}" ]; then
                    err "claude/settings.json にランタイムフィールドが含まれています（コミット禁止）: $(printf '%s' "${bad}" | tr '\n' ' ')"
                    err "  除去してから再コミットしてください（例: git restore --staged claude/settings.json して該当キーを削除）"
                fi
            fi
            ;;
    esac

    # 秘密パターン検知（staged 内容全体を対象。このリポに秘密が存在してよい場所はない）
    if git show ":${f}" 2>/dev/null | /usr/bin/grep -qE "${secret_pat}"; then
        err "秘密情報らしき文字列を検知: ${f}（AWSキー/GitHub PAT/Slack token/APIキー/秘密鍵の形式）"
        err "  実物なら即座に取り消し・ローテーションし、キーチェーン等へ移す。誤検知ならユーザー確認の上で対応を決める"
    fi

    case "${f}" in
        *.sh)
            if ! out="$(git show ":${f}" | bash -n 2>&1)"; then
                err "bash -n 失敗: ${f}"
                printf '%s\n' "${out}" >&2
            fi
            ;;
    esac

    case "${f}" in
        claude/hooks/*.sh)
            run_hook_tests=1
            ;;
    esac
done <<EOF
${staged}
EOF

if [ "${run_hook_tests}" -eq 1 ]; then
    if ! out="$(bash claude/hooks/tests/run-tests.sh 2>&1)"; then
        err "claude/hooks の回帰テストが失敗しました"
        printf '%s\n' "${out}" >&2
    fi
fi

exit "${fail}"

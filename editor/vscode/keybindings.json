// 既定値を上書きするには、このファイル内にキー バインドを挿入しますauto[]
[
  {
    "key": "cmd+y",
    "command": "editor.action.webvieweditor.redo",
    "when": "!editorFocus && !inputFocus && activeEditor == 'WebviewEditor'"
  },
  {
    "key": "shift+cmd+z",
    "command": "-editor.action.webvieweditor.redo",
    "when": "!editorFocus && !inputFocus && activeEditor == 'WebviewEditor'"
  }
]
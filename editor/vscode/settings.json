{
  "workbench.editorAssociations": {
    "*.ipynb": "jupyter-notebook"
  },
  "security.workspace.trust.untrustedFiles": "open",
  "notebook.cellToolbarLocation": {
    "default": "right",
    "jupyter-notebook": "left"
  },
  "editor.wordWrap": "on",
  "explorer.confirmDelete": false,
  "mssql.connections": [
    {
      "server": "{{put-server-name-here}}",
      "database": "{{put-database-name-here}}",
      "user": "{{put-username-here}}",
      "password": ""
    }
  ],
  "hediet.vscode-drawio.theme": "dark",
  "editor.suggestSelection": "first",
  "vsintellicode.modify.editor.suggestSelection": "automaticallyOverrodeDefaultValue",
  "[vue]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "extensions.autoUpdate": "onlyEnabledExtensions",
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[markdown]": {
    "editor.defaultFormatter": "unifiedjs.vscode-remark"
  },
  "editor.unicodeHighlight.allowedCharacters": {
    "：": true,
    "×": true
  },
  "bracket-pair-colorizer-2.depreciation-notice": true,
  "bracketPairColorizer.depreciation-notice": false,
  "workbench.colorTheme": "GitHub Dark Default",
  "go.gopath": "~/go",
  "go.goroot": "/opt/homebrew/Cellar/go/1.24.1/libexec",
  "go.toolsManagement.autoUpdate": true,
  "workbench.startupEditor": "none",
  "npm.keybindingsChangedWarningShown": true,
  "vsicons.dontShowNewVersionMessage": true,
  "workbench.iconTheme": "vscode-icons",
  "editor.fontFamily": "Ricty Diminished",
  "[python]": {
    "editor.formatOnType": true
  },
  "editor.formatOnSave": true,
  "javascript.updateImportsOnFileMove.enabled": "always",
  "notebook.formatOnSave.enabled": true,
  "gitlens.views.worktrees.showBranchComparison": "branch",
  "hediet.vscode-drawio.resizeImages": null,
  "explorer.confirmDragAndDrop": false,
  "phpunit.command": "docker exec -t palmu-api sh -c",
  "github.copilot.editor.enableAutoCompletions": true,
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "makefile.configureOnOpen": true,
  "[sql]": {
    "editor.defaultFormatter": "adpyke.vscode-sql-formatter"
  },
  "workbench.editor.customLabels.patterns": {
    "**/*.go": "${dirname(0)}/${filename}.${extname}"
  },
  "editor.minimap.enabled": true,
  "git.confirmSync": false,
  "git.openRepositoryInParentFolders": "never",
  "workbench.activityBar.orientation": "vertical",
  "go.toolsEnvVars": {
    "GO111MODULE": "on"
  },
  "terminal.integrated.env.osx": {
    "PATH": "/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:/Library/Apple/usr/bin"
  },
  "terminal.external.osxExec": "Warp.app",
  "terminal.external.linuxExec": "Warp.app",
  "[dockercompose]": {
    "editor.insertSpaces": true,
    "editor.tabSize": 2,
    "editor.autoIndent": "advanced",
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "[github-actions-workflow]": {
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "claudeCode.selectedModel": "default",
  "terraform.mcp.server.enable": true,
  "githubPullRequests.pullBranch": "never",
  "claudeCode.preferredLocation": "panel",
  "editor.quickSuggestions": {
    "comments": false,
    "strings": true,
    "other": true
  },
  "cucumberautocomplete.strictGherkinCompletion": true,
  "cucumberautocomplete.onTypeFormat": true,
  "cucumberautocomplete.smartSnippets": true
}
